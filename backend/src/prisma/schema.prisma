generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          Role      @default(MEMBER)
  mustChangePassword Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  groups              UserGroup[]
  tickets             Ticket[]      @relation("TicketCreator")
  comments            Comment[]
  notifications       Notification[]
  viewedTickets       TicketViewer[]
  pushSubscriptions   PushSubscription[]
}

enum Role {
  ADMIN
  PASTORA
  MEMBER
}

model Group {
  id              String   @id @default(uuid())
  name            String
  description     String?
  whatsappGroupId String?
  isPrivate       Boolean  @default(false)
  isPersonal      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members UserGroup[]
  tickets Ticket[]
}

model UserGroup {
  id        String   @id @default(uuid())
  userId    String
  groupId   String
  isLeader  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Ticket {
  id          String     @id @default(uuid())
  title       String
  description String
  status      TicketStatus @default(PENDIENTE_PASTORA)
  priority    TicketPriority?
  visibility  TicketVisibility @default(INICIAL)
  deadline      DateTime?
  autoDeleteAt  DateTime?
  hidden        Boolean    @default(false)
  groupId       String
  createdById String
  group       Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User       @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  comments      Comment[]
  notifications Notification[]
  viewers       TicketViewer[]

  @@index([groupId])
  @@index([status])
  @@index([deadline])
}

enum TicketVisibility {
  INICIAL
  PRIVATE
  PUBLIC
  USER_SPECIFIC
}

model TicketViewer {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ticketId, userId])
}

enum TicketStatus {
  PENDIENTE_APROBACION
  PENDIENTE_PASTORA
  PENDIENTE_REVISION
  APROBADO
  EN_PROGRESO
  COMPLETADO
  RECHAZADO
}

enum TicketPriority {
  ALTA
  MEDIA
  BAJA
}

model Comment {
  id            String   @id @default(uuid())
  ticketId      String
  userId        String
  content       String
  isActionPlan  Boolean  @default(false)
  reviewStatus  ReviewStatus?
  reviewedById  String?
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([ticketId])
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED_BY_LEADER
  REJECTED_BY_LEADER
  SENT_TO_PASTORA
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  ticketId  String?
  message   String
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model BackupLog {
  id          String     @id @default(uuid())
  type        String
  status      String
  fileName    String?
  fileSize    String?
  message     String?
  triggeredBy String
  duration    Int?
  createdAt   DateTime   @default(now())

  @@index([createdAt])
  @@index([status])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}
